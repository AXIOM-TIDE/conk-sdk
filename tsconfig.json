{
  "compilerOptions": {
    "target":               "ES2020",
    "module":               "commonjs",
    "lib":                  ["ES2020", "DOM"],
    "declaration":          true,
    "declarationMap":       true,
    "sourceMap":            true,
    "outDir":               "./dist",
    "rootDir":              "./src",
    "strict":               true,
    "noImplicitAny":        true,
    "strictNullChecks":     true,
    "noUnusedLocals":       false,
    "noUnusedParameters":   false,
    "noImplicitReturns":    true,
    "esModuleInterop":      true,
    "skipLibCheck":         true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":    true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
